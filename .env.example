# ---------------------------------------------------------------------------
# Autonomous RWA Agent — environment template. Copy to .env and fill in.
# ---------------------------------------------------------------------------

# Network
NETWORK=testnet                    # local | testnet  (local requires Docker for xrpl-up)
XRPL_RPC_URL=                      # optional override of the default RPC for NETWORK

# Merchant (operator side)
MERCHANT_SEED=                     # operator-held; if empty, bootstrap generates + funds one
MERCHANT_PORT=8787                 # MPP charge server port
ISSUANCE_INTERVAL_MS=60000         # 0 disables the optional ongoing release loop
RWA_ASSET_SCALE=2
RWA_METADATA=Tokenized RWA demo
RWA_AVAILABLE_UNITS=10             # units available to transfer at launch (inventory, not max supply)
RWA_PRICE=10                       # asking price per unit, in PAYMENT_CURRENCY units (402 challenge)
MPP_SECRET_KEY=                    # mppx server secret (any high-entropy string)

# Payment currency
PAYMENT_CURRENCY=RLUSD             # RLUSD | XRP | IOU(custom)
RLUSD_TESTNET_ISSUER=rQhWct2fv4Vc4KRjRgMrxa8xPN9Zx9iLKV   # matches SDK RLUSD_TESTNET; currency is the 40-char hex code

# Agent
# The ONLY merchant locator the agent is given is the seller's service endpoint.
# It is NOT given the merchant's XRPL address — that is learned from each 402 challenge.
MERCHANT_URL=http://localhost:8787 # seller endpoint the agent reads + pays (default shown)
ANTHROPIC_API_KEY=
AGENT_MODEL=                       # default resolved in code; override here (e.g. claude-sonnet-4-6)
AGENT_MAX_ITERATIONS=40            # bounded control loop
MAX_SPEND=50                       # hard cap in PAYMENT_CURRENCY units, also enforced by OWS policy
OWS_WALLET_NAME=agent-treasury
OWS_PASSPHRASE=                    # owner passphrase OR ows_key_... agent token used to sign
OWS_VAULT_PATH=                    # optional custom OWS vault root (default ~/.ows)

# Swap
SWAP_SLIPPAGE_BPS=100

# Signer fallback (SECURITY DOWNGRADE — off by default; see FINDINGS.md Phase 2.3)
# When true, the MPP payment leg derives the SDK Wallet from a seed instead of OWS.
# Never enable on a trusted/production key. Used only to make the demo runnable until
# the SDK exposes Wallet.fromSigner({ address, publicKey, sign }).
ALLOW_SEED_FALLBACK=false
